# =====================================================
# VPN GAMING APP - Development Environment
# Dùng cho local development
# =====================================================

# Database - kết nối PostgreSQL local
DATABASE_URL=postgresql+psycopg2://vpn_user:VpnSecure@2024@localhost:5432/vpn_app

# JWT
JWT_SECRET=dev-secret-key-not-for-production
JWT_ALG=HS256
JWT_EXPIRE_MIN=60

# App URLs cho development
APP_BASE_URL=http://localhost:8080
VITE_API_BASE_URL=http://localhost:8080

# CORS
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:8080,http://localhost:5173,http://127.0.0.1:5173

# Email - fallback to console trong dev mode
SMTP_FALLBACK_TO_CONSOLE=true

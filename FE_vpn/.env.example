# =====================================================
# FRONTEND ENV CONFIGURATION
# Copy this file to .env.development and .env.production
# Development: cp .env.example .env.development
# =====================================================

# =====================================================
# API BASE URL
# =====================================================
# Vite uses VITE_ prefix to expose env variables to frontend

# API endpoint for backend
# Development (local backend): http://localhost:8080
# Development (Docker backend): http://localhost:8080
# Production (nginx proxy): leave empty (uses same domain)
VITE_API_BASE_URL=http://localhost:8080

# =====================================================
# APP CONFIGURATION
# =====================================================
# Application name/title
VITE_APP_NAME=VPN Gaming Platform

# API request timeout (milliseconds)
VITE_API_TIMEOUT=30000

# =====================================================
# FEATURE FLAGS & DEBUG
# =====================================================
# Enable debug logging
VITE_DEBUG=false

# Use mock API responses (useful for UI development without backend)
VITE_MOCK_API=false
